{
    "name": "mini-orm/mini-orm",
    "description": "A minimal PHP ORM built with clean architecture",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MiniOrm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MiniOrm\\Tests\\": "tests/"
        }
    }
}
